# API_BASE_URL=https://photobox-api.your-domain.workers.dev
API_BASE_URL=http://127.0.0.1:8787
POLL_INTERVAL=10
# Tên máy in, nếu để trống script sẽ gửi lệnh in tới máy in mặc định của hệ điều hành
PRINTER_NAME=
# Nếu bật PRINT_TO_PDF=true/false, script sẽ không in ra máy thật mà sẽ lưu file PDF vào thư mục printed_pdfs/
PRINT_TO_PDF=true
STATION_SLUG=tram1
